    <script>
        // --- Defense Matrix Tab Logic ---
        function showDefense(tabId, btn) {
            // Hide all content
            const contents = document.querySelectorAll('.defense-content');
            contents.forEach(el => {
                el.classList.remove('block');
                el.classList.add('hidden');
            });

            // Remove active styles from all buttons
            const btns = document.querySelectorAll('.defense-tab-btn');
            btns.forEach(el => {
                el.classList.remove('tab-active', 'bg-slate-800', 'text-white');
                el.classList.add('bg-slate-200', 'text-slate-600');
            });

            // Show selected content
            document.getElementById('content-' + tabId).classList.remove('hidden');
            document.getElementById('content-' + tabId).classList.add('block');

            // Add active styles to clicked button
            btn.classList.remove('bg-slate-200', 'text-slate-600', 'hover:bg-slate-300');
            btn.classList.add('tab-active', 'bg-slate-800', 'text-white'); // Slate 800 matches NSA theme
            
            // Re-apply Tailwind classes specific to active state since JS manipulation can be tricky with complex tailwind states if not careful
            btn.style.backgroundColor = '#1e293b';
            btn.style.color = 'white';
            
            btns.forEach(otherBtn => {
                if(otherBtn !== btn) {
                    otherBtn.style.backgroundColor = '';
                    otherBtn.style.color = '';
                }
            })
        }

        // --- Chart.js Implementation for Threat Timeline ---
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('qubitChart').getContext('2d');
            
            // Log scale data visualization tailored for serious reporting
            const data = {
                labels: ['当前顶尖硬件', '理论qLDPC (假定有逻辑门)', '表面码 (主流保守估计)'],
                datasets: [{
                    label: '物理量子比特需求',
                    data: [1121, 500000, 20000000], // 1121 based on IBM Condor approximate
                    backgroundColor: [
                        'rgba(148, 163, 184, 0.7)', // Slate
                        'rgba(239, 68, 68, 0.7)',   // Red
                        'rgba(30, 41, 59, 0.7)'     // Dark Slate
                    ],
                    borderColor: [
                        'rgb(71, 85, 105)',
                        'rgb(185, 28, 28)',
                        'rgb(15, 23, 42)'
                    ],
                    borderWidth: 1,
                    borderRadius: 4
                }]
            };

            const config = {
                type: 'bar',
                data: data,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y', // Horizontal
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            titleFont: { family: "'Noto Sans SC', sans-serif", size: 14 },
                            bodyFont: { family: "'Noto Sans SC', sans-serif", size: 13 },
                            padding: 12,
                            callbacks: {
                                label: function(context) {
                                    return '需 ' + new Intl.NumberFormat('zh-CN').format(context.parsed.x) + ' 物理比特';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            type: 'logarithmic',
                            title: {
                                display: true,
                                text: '所需规模量级 (对数)',
                                font: { family: "'Noto Sans SC', sans-serif", weight: 'bold' }
                            },
                            ticks: {
                                callback: function(value) {
                                    if (value === 1000) return '1,000 (当前)';
                                    if (value === 100000) return '10万';
                                    if (value === 1000000) return '100万';
                                    if (value === 10000000) return '1,000万';
                                    return null;
                                }
                            },
                            grid: { color: '#e2e8f0' }
                        },
                        y: {
                            ticks: {
                                font: { family: "'Noto Sans SC', sans-serif", weight: 'bold' },
                                color: '#1e293b'
                            },
                            grid: { display: false }
                        }
                    }
                }
            };

            new Chart(ctx, config);
        });
    </script>
