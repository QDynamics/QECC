    <!-- JavaScript Logic -->
    <script>
        // --- Obstacle details toggle ---
        function toggleDetail(id) {
            const el = document.getElementById(id);
            if (el.classList.contains('hidden')) {
                el.classList.remove('hidden');
            } else {
                el.classList.add('hidden');
            }
        }

        // --- qLDPC Tab Switcher ---
        function switchTab(tabId, btn) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            // Remove active style from all buttons
            document.querySelectorAll('.tab-btn').forEach(el => {
                el.classList.remove('tab-active', 'text-blue-600');
                el.classList.add('text-slate-500');
            });
            
            // Show selected tab
            document.getElementById(tabId).classList.remove('hidden');
            // Add active style to clicked button
            btn.classList.add('tab-active', 'text-blue-600');
            btn.classList.remove('text-slate-500');
        }

        // --- Chart.js Implementation for Qubit Scaling ---
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('qubitChart').getContext('2d');
            
            // Data representation (estimations for RSA-2048)
            const data = {
                labels: ['当前顶尖硬件', '理论qLDPC (缺逻辑门)', '表面码 Surface Code'],
                datasets: [{
                    label: '所需物理量子比特数量',
                    data: [1000, 500000, 20000000],
                    backgroundColor: [
                        'rgba(148, 163, 184, 0.6)', // slate
                        'rgba(168, 85, 247, 0.6)',  // purple
                        'rgba(59, 130, 246, 0.6)'   // blue
                    ],
                    borderColor: [
                        'rgb(71, 85, 105)',
                        'rgb(126, 34, 206)',
                        'rgb(29, 78, 216)'
                    ],
                    borderWidth: 1,
                    borderRadius: 4
                }]
            };

            const config = {
                type: 'bar',
                data: data,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y', // Horizontal bar for easier reading of labels
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.parsed.x !== null) {
                                        // Format large numbers
                                        label += new Intl.NumberFormat('zh-CN').format(context.parsed.x);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            type: 'logarithmic',
                            title: {
                                display: true,
                                text: '物理量子比特数 (对数刻度)',
                                font: {
                                    family: "'Noto Sans SC', sans-serif"
                                }
                            },
                            ticks: {
                                callback: function(value, index, values) {
                                    // Custom formatting for log scale to look clean
                                    if (value === 1000) return '1千';
                                    if (value === 100000) return '10万';
                                    if (value === 1000000) return '100万';
                                    if (value === 10000000) return '1000万';
                                    if (value === 100000000) return '1亿';
                                    return null; // hide other ticks
                                }
                            }
                        },
                        y: {
                            ticks: {
                                font: {
                                    family: "'Noto Sans SC', sans-serif",
                                    weight: 'bold'
                                }
                            }
                        }
                    }
                }
            };

            new Chart(ctx, config);
        });
    </script>
